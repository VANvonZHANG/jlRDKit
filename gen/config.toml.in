# WrapIt configuration for RDKit CxxWrap wrapper
module_name = "RDKit"
uuid = "e6a2f8d1-7b3c-4d9a-b5e2-f1a3c8d7e9b2"

# Input: RDKit core headers (bare filenames, resolved via include_dirs)
input = [
    "RDGeneral/types.h",
    "RDGeneral/RDProps.h",
    "GraphMol/Atom.h",
    "GraphMol/Bond.h",
    "GraphMol/ROMol.h",
    "GraphMol/RWMol.h",
    "GraphMol/Conformer.h",
    "GraphMol/RingInfo.h",
    "GraphMol/StereoGroup.h",
    "GraphMol/MonomerInfo.h",
    "GraphMol/MolOps.h",
    "GraphMol/SmilesParse/SmilesParse.h",
    "GraphMol/SmilesParse/SmilesWrite.h"
]

# Include directories (resolved at build time from Julia JLL packages)
include_dirs = [
    "@RDKIT_INCLUDE_DIR@",
    "@RDKIT_ROOT_INCLUDE_DIR@",
    "@JLCXX_INCLUDE_DIR@",
    "@JULIA_INCLUDE_DIR@",
    "/usr/include",
    "@BOOST_ROOT_INCLUDE_DIR@",
    "@BOOST_INCLUDE_DIR@"
]

# C++ standard
cxx-std = "c++20"

# Generation control
propagation_mode = "types"
auto_veto = true
n_classes_per_file = 0
fields_and_variables = true

# RDKit uses RDKIT_*_EXPORT macros that must be cleared
clang_opts = [
    "-DRDKIT_GRAPHMOL_EXPORT=",
    "-DRDKIT_RDKIT_EXPORT=",
    "-DRDKIT_RDGENERAL_EXPORT=",
    "-DRDKIT_SMILESPARSE_EXPORT=",
    "-DRDKIT_FILEPARSERS_EXPORT=",
    "-DRDKIT_SUBSTRUCTMATCH_EXPORT="
]

# Inheritance declarations
inheritances = [
    "RWMol:ROMol",
    "QueryAtom:Atom",
    "QueryBond:Bond"
]

# Veto file for problematic types
veto_list = "gen/veto.h"

# Output paths
output-prefix = "libRDKit"
